#!/usr/bin/env bash

## Description: Pull remote database to local SQL file
## Usage: db-pull
## Example: "ddev db-pull prod" or "ddev db-pull dev"

set -e

cd "$DDEV_APPROOT" || exit

# Colors
red='\033[0;31m'
yellow='\033[1;33m'
green='\033[0;32m'
NC='\033[0m'

# Clean up secrets on exit or interrupt
cleanup() {
  [ -n "$SSH_KEY_FILE" ] && rm -f "$SSH_KEY_FILE"
}
trap cleanup EXIT

# Validate environment argument
if [ -z "$1" ] || { [ "$1" != "prod" ] && [ "$1" != "dev" ]; }; then
  echo -e "${yellow}Specify an environment: ddev db-pull prod${NC}"
  echo -e "${yellow}                        ddev db-pull dev${NC}"
  exit 1
fi

ENV="$1"

# Require 1Password CLI
if ! command -v op &>/dev/null; then
  echo -e "${red}1Password CLI (op) is required but not found.${NC}"
  exit 1
fi

# Set environment-specific values
if [ "$ENV" == "prod" ]; then
  OP_ENV="production"
  REMOTE_HOST="bmxfeed.com"
  OUTPUT="aggro-db-$(date +%Y-%m-%d).sql"
else
  OP_ENV="development"
  REMOTE_HOST="dev.bmxfeed.com"
  OUTPUT="aggro-db-dev-$(date +%Y-%m-%d).sql"
fi

# Check if output file already exists
if [ -f "$OUTPUT" ]; then
  echo -e "${yellow}File already exists: ${OUTPUT}${NC}"
  read -r -p "Overwrite? Type 'yes' to continue: " CONFIRM
  if [ "$CONFIRM" != "yes" ]; then
    echo "Aborted."
    exit 0
  fi
fi

# Confirmation prompt
echo -e "${yellow}This will dump the ${ENV} database to ${OUTPUT}.${NC}"
read -r -p "Type 'yes' to continue: " CONFIRM
if [ "$CONFIRM" != "yes" ]; then
  echo "Aborted."
  exit 0
fi

# Load SSH key from 1Password into the DDEV container
OP_VAULT_ITEM="op://Aggro/${OP_ENV}/SSH_PRIVATE_KEY"
SSH_KEY_FILE=$(mktemp)
if op read "$OP_VAULT_ITEM" > "$SSH_KEY_FILE" 2>/dev/null; then
  chmod 600 "$SSH_KEY_FILE"
  docker cp "$SSH_KEY_FILE" "ddev-${DDEV_SITENAME}-web:/tmp/op_ssh_key"
  ddev exec bash -c "chmod 600 /tmp/op_ssh_key && ssh-add /tmp/op_ssh_key && rm -f /tmp/op_ssh_key"
else
  echo -e "${red}Failed to read SSH key from 1Password.${NC}"
  exit 1
fi
rm -f "$SSH_KEY_FILE"

# Read DB credentials from 1Password
echo -e "${yellow}Reading database credentials from 1Password...${NC}"
DB_HOST=$(op read "op://Aggro/${OP_ENV}/DB_HOSTNAME")
DB_NAME=$(op read "op://Aggro/${OP_ENV}/DB_NAME")
DB_USER=$(op read "op://Aggro/${OP_ENV}/DB_USERNAME")
DB_PASS=$(op read "op://Aggro/${OP_ENV}/DB_PASSWORD")

# Run mysqldump over SSH via the DDEV container
echo -e "${yellow}Dumping ${ENV} database...${NC}"
ddev exec ssh -o StrictHostKeyChecking=accept-new "bmxfeed@${REMOTE_HOST}" \
  "mysqldump --single-transaction -h '${DB_HOST}' -u '${DB_USER}' -p'${DB_PASS}' '${DB_NAME}'" \
  > "$OUTPUT"

# Report result
FILE_SIZE=$(du -h "$OUTPUT" | cut -f1)
echo -e "${green}Database saved to ${OUTPUT} (${FILE_SIZE})${NC}"
