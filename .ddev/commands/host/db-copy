#!/usr/bin/env bash

## Description: Copy database between remote environments
## Usage: db-copy
## Example: "ddev db-copy prod dev"

set -e

cd "$DDEV_APPROOT" || exit

# Colors
red='\033[0;31m'
yellow='\033[1;33m'
green='\033[0;32m'
NC='\033[0m'

# Clean up secrets on exit or interrupt
cleanup() {
  [ -n "$SSH_KEY_FILE_SRC" ] && rm -f "$SSH_KEY_FILE_SRC"
  [ -n "$SSH_KEY_FILE_DEST" ] && rm -f "$SSH_KEY_FILE_DEST"
}
trap cleanup EXIT

# Validate arguments
if [ -z "$1" ] || [ -z "$2" ]; then
  echo -e "${yellow}Specify source and destination: ddev db-copy prod dev${NC}"
  exit 1
fi

if { [ "$1" != "prod" ] && [ "$1" != "dev" ]; } || { [ "$2" != "prod" ] && [ "$2" != "dev" ]; }; then
  echo -e "${yellow}Valid environments: prod, dev${NC}"
  echo -e "${yellow}Example: ddev db-copy prod dev${NC}"
  exit 1
fi

if [ "$1" == "$2" ]; then
  echo -e "${red}Source and destination cannot be the same.${NC}"
  exit 1
fi

SOURCE="$1"
DEST="$2"

# Hard-block copy to production
if [ "$DEST" == "prod" ]; then
  echo -e "${red}Copying to production is not allowed.${NC}"
  exit 1
fi

# Require 1Password CLI
if ! command -v op &>/dev/null; then
  echo -e "${red}1Password CLI (op) is required but not found.${NC}"
  exit 1
fi

# Confirmation prompt
echo -e "${yellow}This will overwrite the ${DEST} database with ${SOURCE} data.${NC}"
read -r -p "Type 'yes' to continue: " CONFIRM
if [ "$CONFIRM" != "yes" ]; then
  echo "Aborted."
  exit 0
fi

# Map environment names to 1Password and host values
env_to_op() {
  if [ "$1" == "prod" ]; then echo "production"; else echo "development"; fi
}
env_to_host() {
  if [ "$1" == "prod" ]; then echo "bmxfeed.com"; else echo "dev.bmxfeed.com"; fi
}

SRC_OP=$(env_to_op "$SOURCE")
DEST_OP=$(env_to_op "$DEST")
SRC_HOST=$(env_to_host "$SOURCE")
DEST_HOST=$(env_to_host "$DEST")

# Load SSH keys from 1Password into the DDEV container
echo -e "${yellow}Loading SSH keys from 1Password...${NC}"
for OP_ENV in "$SRC_OP" "$DEST_OP"; do
  SSH_KEY_FILE_SRC=$(mktemp)
  if op read "op://Aggro/${OP_ENV}/SSH_PRIVATE_KEY" > "$SSH_KEY_FILE_SRC" 2>/dev/null; then
    chmod 600 "$SSH_KEY_FILE_SRC"
    docker cp "$SSH_KEY_FILE_SRC" "ddev-${DDEV_SITENAME}-web:/tmp/op_ssh_key"
    ddev exec bash -c "chmod 600 /tmp/op_ssh_key && ssh-add /tmp/op_ssh_key && rm -f /tmp/op_ssh_key"
  else
    echo -e "${red}Failed to read SSH key for ${OP_ENV} from 1Password.${NC}"
    exit 1
  fi
  rm -f "$SSH_KEY_FILE_SRC"
done

# Read DB credentials for both environments
echo -e "${yellow}Reading database credentials from 1Password...${NC}"
SRC_DB_HOST=$(op read "op://Aggro/${SRC_OP}/DB_HOSTNAME")
SRC_DB_NAME=$(op read "op://Aggro/${SRC_OP}/DB_NAME")
SRC_DB_USER=$(op read "op://Aggro/${SRC_OP}/DB_USERNAME")
SRC_DB_PASS=$(op read "op://Aggro/${SRC_OP}/DB_PASSWORD")

DEST_DB_HOST=$(op read "op://Aggro/${DEST_OP}/DB_HOSTNAME")
DEST_DB_NAME=$(op read "op://Aggro/${DEST_OP}/DB_NAME")
DEST_DB_USER=$(op read "op://Aggro/${DEST_OP}/DB_USERNAME")
DEST_DB_PASS=$(op read "op://Aggro/${DEST_OP}/DB_PASSWORD")

# Dump from source, pipe to destination via the DDEV container
echo -e "${yellow}Copying ${SOURCE} database to ${DEST}...${NC}"
ddev exec bash -c "ssh -o StrictHostKeyChecking=accept-new 'bmxfeed@${SRC_HOST}' \
  \"mysqldump --single-transaction -h '${SRC_DB_HOST}' -u '${SRC_DB_USER}' -p'${SRC_DB_PASS}' '${SRC_DB_NAME}'\" \
  | ssh -o StrictHostKeyChecking=accept-new 'bmxfeed@${DEST_HOST}' \
  \"mysql -h '${DEST_DB_HOST}' -u '${DEST_DB_USER}' -p'${DEST_DB_PASS}' '${DEST_DB_NAME}'\""

echo -e "${green}Successfully copied ${SOURCE} database to ${DEST}.${NC}"
