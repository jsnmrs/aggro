#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

CI_ENVIRONMENT=production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app_baseURL="op://Aggro/production/BASE_URL"

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

database_default_hostname="op://Aggro/production/DB_HOSTNAME"
database_default_database="op://Aggro/production/DB_NAME"
database_default_username="op://Aggro/production/DB_USERNAME"
database_default_password="op://Aggro/production/DB_PASSWORD"
database_default_DBDriver=MySQLi

UA_BMXFEED="Aggro (https:/github.com/jsnmrs/aggro)"
UA_SPOOF="Aggro (https:/github.com/jsnmrs/aggro)"

#--------------------------------------------------------------------
# SENTRY
#--------------------------------------------------------------------

SENTRY_DSN="op://Aggro/production/SENTRY_DSN"
SENTRY_ENVIRONMENT="production"
SENTRY_RELEASE=""
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false
